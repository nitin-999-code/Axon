# ─── Server ────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Database ──────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/axon_db?schema=public"

# ─── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
